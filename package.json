    "drizzle-orm": "^0.45.2",
    "fs-extra": "^11.3.4",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "0.28.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
